# =================================
# ECOMMERCE BACKEND - ENVIRONMENT VARIABLES
# =================================
# IMPORTANTE: Nunca commite este arquivo no Git!
# Adicione '.env' no seu .gitignore

# =================================
# APPLICATION PROFILE
# =================================
SPRING_PROFILES_ACTIVE=dev

# =================================
# SERVER CONFIGURATION
# =================================
SERVER_PORT=8080
SHUTDOWN_TIMEOUT=30s

# =================================
# DATABASE CONFIGURATION
# =================================
DATABASE_URL=jdbc:postgresql://postgres:5432/ecommerce
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DB_POOL_SIZE=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=20000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# =================================
# REDIS CONFIGURATION
# =================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000ms

# =================================
# KAFKA CONFIGURATION
# =================================
KAFKA_SERVERS=kafka:9092
KAFKA_GROUP_ID=ecommerce-group
KAFKA_RETRIES=3

# =================================
# JWT CONFIGURATION
# =================================
# IMPORTANTE: Mude esta chave em produção!
JWT_SECRET=minha-super-chave-secreta-para-jwt-deve-ter-pelo-menos-256-bits-para-ser-segura
JWT_EXPIRATION=86400000

# =================================
# LOGGING CONFIGURATION
# =================================
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=DEBUG
SQL_LOG_LEVEL=DEBUG
SQL_PARAMS_LOG_LEVEL=TRACE
SHOW_SQL=true
FORMAT_SQL=true

# =================================
# MONITORING/ACTUATOR
# =================================
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
HEALTH_SHOW_DETAILS=when-authorized
PROMETHEUS_ENABLED=true

# =================================
# APPLICATION METADATA
# =================================
APP_VERSION=1.0.0
ENVIRONMENT=development