# =================================
# ECOMMERCE BACKEND - ENVIRONMENT VARIABLES
# =================================

# Application Profile
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8080
SHUTDOWN_TIMEOUT=30s

# Database Configuration
DATABASE_URL=jdbc:postgresql://postgres:5432/ecommerce
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DB_POOL_SIZE=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=20000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000ms

# Kafka Configuration
KAFKA_SERVERS=kafka:9092
KAFKA_GROUP_ID=ecommerce-group
KAFKA_RETRIES=3

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-long-please-change-this-in-production
JWT_EXPIRATION=86400000

# Logging Configuration
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=DEBUG
SQL_LOG_LEVEL=DEBUG
SQL_PARAMS_LOG_LEVEL=TRACE
SHOW_SQL=true
FORMAT_SQL=true

# Actuator/Monitoring
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
HEALTH_SHOW_DETAILS=when-authorized
PROMETHEUS_ENABLED=true

# Application Metadata
APP_VERSION=1.0.0
ENVIRONMENT=development